// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-dockerfile
{
	"name": "Flare Faucet QA",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "features": {
        "ghcr.io/devcontainers/features/node:1": {
            "version": "20"
        }
    },
    "postCreateCommand": "npm install -g @anthropic-ai/claude-code && uv sync",
    "mounts": [
        "source=/dev/null,target=${containerWorkspaceFolder}/.env,type=bind,readonly",
        "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind",
        "source=${localEnv:HOME}/.claude.json,target=/home/vscode/.claude.json,type=bind"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.black-formatter",
                "mikestead.dotenv",
                "eamodio.gitlens",
                "usernamehw.errorlens",
                "ms-azuretools.vscode-docker",
                "christian-kohler.path-intellisense",
                "wayou.vscode-todo-highlight",
                "pkief.material-icon-theme"
            ],
            "settings": {
                "[python]": {
                    "editor.defaultFormatter": "ms-python.black-formatter",
                    "editor.tabSize": 4
                },
                "editor.insertSpaces": true,
                "editor.detectIndentation": false,
                "files.trimFinalNewlines": true,
                "files.trimTrailingWhitespace": true,
                "yaml.customTags": [
                    "!reference sequence"
                ]
            }
        }
    }
}
